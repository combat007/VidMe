DATABASE_URL=postgresql://vidme_user:vidme_pass@postgres:5432/vidme_db
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
PINATA_API_KEY=your_pinata_api_key
PINATA_API_SECRET=your_pinata_api_secret
PINATA_JWT=your_pinata_jwt_token
PORT=3000
NODE_ENV=development

# Email (for forgot-password OTP). Leave blank to print codes to backend logs instead.
# Gmail example: SMTP_HOST=smtp.gmail.com  SMTP_PORT=587  SMTP_USER=you@gmail.com  SMTP_PASS=app-password
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@vidme.app

# OAuth — Google (https://console.cloud.google.com → APIs & Services → Credentials)
# Create a Web OAuth 2.0 client; add your domain to Authorised JavaScript Origins
# and https://www.vidmez.com/api/auth/google/callback to Authorised Redirect URIs
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# OAuth — GitHub (https://github.com/settings/developers → New OAuth App)
# Homepage URL: https://www.vidmez.com
# Callback URL:  https://www.vidmez.com/api/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Public frontend URL (used to build GitHub redirect URIs and post-OAuth redirects)
FRONTEND_URL=https://www.vidmez.com
