# PostgreSQL (used by backend)
DATABASE_URL=postgresql://vidme_user:vidme_pass@postgres:5432/vidme_db

# JWT signing secret — change this!
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# Pinata IPFS credentials — get from https://app.pinata.cloud/keys
PINATA_API_KEY=your_pinata_api_key
PINATA_API_SECRET=your_pinata_api_secret
PINATA_JWT=your_pinata_jwt

# Frontend API URL (used by nginx env substitution)
API_BASE_URL=https://your-server-ip-or-domain
