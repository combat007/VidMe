# PostgreSQL (used by backend)
DATABASE_URL=postgresql://vidme_user:vidme_pass@postgres:5432/vidme_db

# JWT signing secret — change this!
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# Filebase IPFS credentials — get from https://console.filebase.com/keys
FILEBASE_KEY=your_filebase_access_key
FILEBASE_SECRET=your_filebase_secret_key
FILEBASE_BUCKET=your_filebase_bucket_name

# Frontend API URL (used by nginx env substitution)
API_BASE_URL=https://your-server-ip-or-domain
